{
  "expo": {
    "name": "Alarms & Clock",
    "slug": "alarms-and-clock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0078D7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.jpg",
        "backgroundColor": "#0078D7"
      },
      "package": "com.cyanexani.metroosclock"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
